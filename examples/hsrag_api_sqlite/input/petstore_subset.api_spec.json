{
  "service_name": "petstore-demo",
  "api_version": "v1",
  "source_type": "demo_petstore_style_fixed_sample",
  "evidence_class": "FHS",
  "tacl_layer": "L0",
  "contract_role": "core",
  "endpoints": [
    {
      "method": "GET",
      "path": "/pet/{petId}",
      "summary": "Find pet by ID.",
      "parameters": {
        "path": {
          "petId": {
            "type": "integer",
            "required": true
          }
        }
      },
      "responses": {
        "200": {
          "description": "Pet found."
        },
        "404": {
          "description": "Pet not found."
        }
      },
      "constraints": {
        "auth_required": false,
        "sample_only": true
      }
    },
    {
      "method": "POST",
      "path": "/pet",
      "summary": "Add a new pet to the store.",
      "parameters": {
        "body": {
          "name": {
            "type": "string",
            "required": true
          },
          "status": {
            "type": "string",
            "required": false
          }
        }
      },
      "responses": {
        "200": {
          "description": "Pet added."
        },
        "400": {
          "description": "Invalid input."
        }
      },
      "constraints": {
        "auth_required": false,
        "sample_only": true
      }
    },
    {
      "method": "DELETE",
      "path": "/pet/{petId}",
      "summary": "Delete a pet by ID.",
      "parameters": {
        "path": {
          "petId": {
            "type": "integer",
            "required": true
          }
        }
      },
      "responses": {
        "200": {
          "description": "Pet deleted."
        },
        "404": {
          "description": "Pet not found."
        }
      },
      "constraints": {
        "auth_required": false,
        "sample_only": true
      }
    }
  ]
}
