{
  "service_name": "demo-user-service",
  "api_version": "v1",
  "source_type": "official_demo_spec",
  "evidence_class": "FHS",
  "tacl_layer": "L0",
  "contract_role": "core",
  "endpoints": [
    {
      "method": "GET",
      "path": "/users/{id}",
      "summary": "Get a user by ID.",
      "parameters": {
        "path": {
          "id": {
            "type": "string",
            "required": true
          }
        }
      },
      "responses": {
        "200": {
          "description": "User found."
        },
        "404": {
          "description": "User not found."
        }
      },
      "constraints": {
        "auth_required": true
      }
    },
    {
      "method": "POST",
      "path": "/users",
      "summary": "Create a new user.",
      "parameters": {
        "body": {
          "name": {
            "type": "string",
            "required": true
          }
        }
      },
      "responses": {
        "201": {
          "description": "User created."
        },
        "400": {
          "description": "Invalid request."
        }
      },
      "constraints": {
        "auth_required": true
      }
    }
  ]
}
